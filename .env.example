VITE_API_BASE_URL=https://your-region-your-project-id.cloudfunctions.net/api # 여기에 배포된 Firebase Function URL을 넣으세요 (예: https://asia-northeast3-my-project.cloudfunctions.net/api)
VITE_KAKAO_MAP_KEY=your_kakao_javascript_key_here

# Firebase 설정
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id

# 추가 API 키 (클라이언트 측에서 직접 사용될 수 있는 경우)
